# ─────────────────────────────────────────────────────────────────────────────
# Prescient LabsV2 environment variables
#
# In Replit: paste each KEY=value pair into Tools → Secrets.
# Do NOT commit real values. This file is the template only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
DATABASE_URL=

# ── Auth ────────────────────────────────────────────────────────────────────
# Required in production. If unset, the server will exit on boot.
JWT_SECRET=
SESSION_SECRET=

# ── Stripe — public config ──────────────────────────────────────────────────
# Get these from your Stripe Dashboard → Developers → API keys.
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME

# Auto-created by stripe-replit-sync on first server boot.
# If missing, copy from Stripe Dashboard → Developers → Webhooks.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── Stripe — price IDs (live mode) ─────────────────────────────────────────
# Replace with the price IDs from your own Stripe account. Do not commit
# real values — set them via Replit Secrets in production.
STRIPE_PRICE_MONTHLY_STARTER=price_REPLACE_ME
STRIPE_PRICE_ANNUAL_STARTER=price_REPLACE_ME
STRIPE_PRICE_MONTHLY_GROWTH=price_REPLACE_ME
STRIPE_PRICE_ANNUAL_GROWTH=price_REPLACE_ME
STRIPE_PRICE_USAGE_BASED=price_REPLACE_ME
STRIPE_PRICE_PERFORMANCE=price_REPLACE_ME

# ── Optional integrations ───────────────────────────────────────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# SENDGRID_API_KEY=
# REPLIT_DOMAINS=
