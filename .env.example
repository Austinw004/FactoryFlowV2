# ─────────────────────────────────────────────────────────────────────────────
# Prescient LabsV2 environment variables
#
# In Replit: paste each KEY=value pair into Tools → Secrets.
# Do NOT commit real values. This file is the template only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
DATABASE_URL=

# ── Auth ────────────────────────────────────────────────────────────────────
# Required in production. If unset, the server will exit on boot.
JWT_SECRET=
SESSION_SECRET=

# ── Stripe — public config ──────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/acct_1SZFrW9F4Ysa19m8/apikeys
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME

# Auto-created by stripe-replit-sync on first server boot.
# If missing, copy from Stripe Dashboard → Developers → Webhooks.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── Stripe — Prescient LabsV2 price IDs (live mode) ────────────────────────────
# These map to Prescient Labs Inc (acct_1SZFrW9F4Ysa19m8) products.
STRIPE_PRICE_MONTHLY_STARTER=price_1TLvZh9F4Ysa19m8rrNdtZ7b
STRIPE_PRICE_ANNUAL_STARTER=price_1TLvZi9F4Ysa19m8DGXyivla
STRIPE_PRICE_MONTHLY_GROWTH=price_1TLvZj9F4Ysa19m86mw8fPZb
STRIPE_PRICE_ANNUAL_GROWTH=price_1TLvZk9F4Ysa19m8idqygXcf
STRIPE_PRICE_USAGE_BASED=price_1TLvZl9F4Ysa19m8JUrRFfRo
STRIPE_PRICE_PERFORMANCE=price_1TLvZm9F4Ysa19m8Vzo9RcqH

# ── Optional integrations ───────────────────────────────────────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# SENDGRID_API_KEY=
# REPLIT_DOMAINS=
